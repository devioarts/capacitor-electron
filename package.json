{
  "name": "@devioarts/capacitor-electron",
  "version": "0.1.1",
  "description": "Capacitor platform for Electron — CLI tools and templates",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/shared/types.d.ts",
      "import": "./dist/shared/types.js",
      "require": "./dist/shared/types.cjs"
    },
    "./globals": {
      "types": "./dist/shared/globals.d.ts"
    }
  },
  "types": "./dist/shared/types.d.ts",
  "files": [
    "dist",
    "template-electron.tar.gz"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "lint": "eslint src/cli src/shared tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build",
    "release": "npm publish --access public",
    "capacitor:sync:after": "npx cap-electron sync",
    "capacitor:copy:after": "npx cap-electron copy",
    "capacitor:update:after": "npx cap-electron update"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devioarts/capacitor-electron"
  },
  "bin": {
    "cap-electron": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "capacitor": {
    "electron": {
      "binary": "cap-electron",
      "platforms": [
        "electron"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "capacitor",
    "electron",
    "platform"
  ],
  "peerDependencies": {
    "@capacitor/cli": ">=8.0.0"
  },
  "dependencies": {
    "tar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.0.0",
    "electron": "^42.4.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
